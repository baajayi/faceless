# ============================================================
# Faceless TikTok Video Pipeline — Environment Variables
# Copy this to .env and fill in your values.
# ============================================================

# --- Database & Broker ---
DATABASE_URL=postgresql://faceless:faceless@postgres:5432/faceless
REDIS_URL=redis://redis:6379/0

# --- AI APIs ---
OPENAI_API_KEY=sk-...
YOUTUBE_API_KEY=AIza...

# --- Pipeline Config ---
REGION=US
POST_TIME=06:00
AGE_BAND=4-10
VISUAL_STYLE=cartoon          # cartoon | paper-cut | 3d-toy | whiteboard

# --- TTS / Voice ---
VOICE_PROVIDER=openai
VOICE_ID=nova                 # OpenAI TTS voices: alloy, echo, fable, nova, onyx, shimmer

# --- Music ---
MUSIC_MODE=none               # none | royalty_free | generated

# --- Publishing ---
PUBLISH_MODE=C                # A | B | C  (C = manual export package)

# --- Safety ---
SAFETY_STRICTNESS=high        # low | med | high

# --- Cost Guard ---
COST_LIMIT_PER_DAY=5.0        # USD hard cap per daily run

# --- Observability ---
SLACK_WEBHOOK_URL=            # Optional: https://hooks.slack.com/...
LOG_LEVEL=INFO

# --- Storage ---
ARTIFACTS_DIR=/app/output

# --- TikTok API (MODE_A only — leave blank for MODE_C) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
